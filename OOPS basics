class BankAccount:
    def __init__(self,name,balance=0):
        self.name=name
        self.balance=balance
        
    def withdraw(self,money:int):
        if self.balance>=money:
            self.balance-=money
            print(f"{money} has been withdrawn sucessfully. Remaining balance: {self.balance}")
        else:
            print("Insufficient amount.")
            
    def get_balance(self):
        return f'Balance:{self.balance}.'
        
    def credit(self,money:int):
        self.balance+=money
        print(f"{money} has sucessfully credited. Remaining balance: {self.balance}.")
        
Trishul=BankAccount('hdfc',1400)
Trishul.credit(100)
Trishul.withdraw(400)
print(Trishul.get_balance())


class Vehicle:
    def __init__(self,model:str,power:int):
        self.model=model
        self.power=power
        self.ignition=False

    def turn_on(self):
        if self.ignition:
            print(f"{self.model} is already turned on.")
        else:
            print(f"{self.model} is now turned on.")
            self.ignition=True
            
    def turn_off(self):
        if self.ignition:
            print(f"{self.model} is now turned off.")
            self.ignition=False
        else:
            print(f"{self.model} is already turned off.")
            
    def drive(self):
        if self.ignition:
            print(f"{self.model} is now being driven.")
        else:
            print(f"Kindly turn on the ignition of the {self.model}.")


class Bike(Vehicle):
    def __init__(self,model,power,colour):
        super().__init__(model,power)
        self.colour=colour

class Truck(Vehicle):
    def __init__(self,model,power,load_capacity):
        super().__init__(model,power)
        self.load_capacity=load_capacity

class Bull_dozer(Truck):
    def __init__(self,model,power,transmission,load_capacity):
        super().__init__(model,power,load_capacity)
        self.transmission=transmission

car=Vehicle('Audi',150)
car.turn_on()


eicher=Truck('Pro 2049',75,5)
eicher.drive()
Kawasaki=Bike('Ninja',90,'Green')
Kawasaki.turn_on()
Kawasaki.drive()
Kawasaki.turn_off()
